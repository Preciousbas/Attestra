# 0G Compute (Router) — https://pc.0g.ai
ZG_COMPUTE_API_KEY=
ZG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
ZG_COMPUTE_MODEL=zai-org/GLM-5-FP8

# Market data: coingecko (default, free) | auto | binance
MARKET_DATA_PROVIDER=coingecko

# Server (local dev)
PORT=8787
VITE_API_URL=http://localhost:8787

# 0G Chain (Galileo testnet) — https://faucet.0g.ai
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602
ZG_PRIVATE_KEY=
ZG_REGISTRY_ADDRESS=0xDDdaf4F3a28cDD8eC0BdE5615b335b325D9193c9
ZG_AGENTIC_ID_ADDRESS=0x6710bb44a1EECc0e2F55887852A637E8ecF37DcE
ZG_AGENTIC_TRANSFER_MODE=standard
ZG_EXPLORER_URL=https://chainscan-galileo.0g.ai

# 0G Storage
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Optional — contract verify (npm run verify:registry)
# ZG_EXPLORER_API_URL=
# ETHERSCAN_API_KEY=

# CI/scripts only — never set in production or Netlify
# ATTEST_SKIP_WALLET_AUTH=1

# Netlify: npx netlify env:import .env
# Do NOT set VITE_API_URL or PORT in Netlify — VITE_API_URL=/api is in netlify.toml.
