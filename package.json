{
  "name": "attestra",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Attestra — verifiable AI trading intelligence on 0G",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:market": "tsx scripts/test-binance.ts",
    "test:proof": "tsx scripts/test-proof.ts",
    "test:wallet-auth": "tsx scripts/test-wallet-auth.ts",
    "test:binance": "tsx scripts/test-binance.ts",
    "test:compute": "tsx scripts/test-compute.ts",
    "diagnose": "tsx scripts/diagnose-network.ts",
    "compile:contract": "tsx scripts/compile-contract.ts",
    "forge:build": "tsx scripts/compile-contract.ts",
    "forge:fmt": "forge fmt",
    "forge:fmt:check": "forge fmt --check",
    "deploy:registry": "tsx scripts/deploy-registry.ts",
    "deploy:agentic": "tsx scripts/deploy-agentic.ts",
    "deploy:registry:forge": "forge script script/DeploySignalRegistry.s.sol:DeploySignalRegistry --rpc-url og_testnet --broadcast",
    "deploy:agentic:forge": "forge script script/DeployAgenticID.s.sol:DeployAgenticID --rpc-url og_testnet --broadcast",
    "transfer:agentic": "tsx scripts/transfer-agentic-id.ts",
    "verify:registry": "tsx scripts/verify-registry.ts",
    "anchor:signal": "tsx scripts/anchor-signal.ts",
    "e2e:attest": "tsx scripts/e2e-attest.ts",
    "test:all": "npm run typecheck && npm run build && npm run forge:fmt:check && npm run test:contract:ci && npm run test:contract:coverage && npm run test:contract:hardhat && npm run diagnose && npm run test:market && npm run test:wallet-auth && ATTEST_SKIP_WALLET_AUTH=1 npm run e2e:attest -- --mock",
    "test:contract": "forge test -vv",
    "test:contract:ci": "FOUNDRY_PROFILE=ci forge test -vv",
    "test:contract:coverage": "FOUNDRY_PROFILE=coverage forge coverage --match-contract 'AgenticIDTest|SignalRegistryTest' --report summary",
    "test:contract:coverage:full": "forge coverage --report summary",
    "test:contract:hardhat": "hardhat test",
    "typecheck": "tsc -b --noEmit",
    "deploy:netlify": "netlify deploy --build",
    "deploy:netlify:prod": "netlify deploy --prod --build"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.8",
    "@netlify/blobs": "^10.7.9",
    "@openzeppelin/contracts": "^5.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.0",
    "express": "^5.1.0",
    "openai": "^5.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "chai": "^4.5.0",
    "concurrently": "^9.1.2",
    "hardhat": "^2.24.0",
    "hardhat-gas-reporter": "^1.0.10",
    "netlify-cli": "^26.1.0",
    "solc": "^0.8.30",
    "solidity-coverage": "^0.8.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typechain": "^8.3.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
